---
import HeroScene from './HeroScene.astro';
import { headlines } from '../scripts/hero-headlines';

const proof = ['Mastercard', 'Vocalink', 'Rackspace', '700h → 1h automation'];
const initial = headlines[0];
---

<section class="relative overflow-hidden border-b border-zinc-800 pt-28 pb-20 md:pt-36 md:pb-28">
	<div
		class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,#27272a_1px,transparent_1px),linear-gradient(to_bottom,#27272a_1px,transparent_1px)] bg-size-[4rem_4rem] mask-[radial-gradient(ellipse_80%_60%_at_50%_0%,#000_40%,transparent_100%)] opacity-30"
		aria-hidden="true"
	>
	</div>

	<div class="relative mx-auto max-w-7xl px-6 md:px-10">
		<div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-8">
			<div class="md:col-span-8">
				<p class="mb-6 font-mono text-xs uppercase tracking-[0.25em] text-accent">
					Full-Stack Product & Platform Engineering
				</p>

				<h1
					class="hero-headline min-h-[2.4em] text-4xl leading-[1.05] font-light tracking-tight text-white md:min-h-[2.3em] md:text-6xl lg:text-7xl"
					data-hero-headline
					aria-live="polite"
				>
					<span data-hero-lead>{initial.lead}</span>
					<span class="block font-normal text-zinc-400" data-hero-sub>{initial.sub}</span>
				</h1>

				<p class="mt-8 max-w-2xl text-lg leading-relaxed text-zinc-400 md:text-xl">
					S/NERGY LABS builds production software - web, mobile, and developer tooling backed by cloud infrastructure engineered to scale seamlessly and optimise costs.
				</p>

				<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
					<a
						href="#contact"
						class="inline-flex items-center justify-center bg-accent px-8 py-4 font-mono text-sm uppercase tracking-widest text-white transition-colors hover:bg-accent-hover"
					>
						Schedule a Strategy Call
					</a>
					<a
						href="#work"
						class="inline-flex items-center justify-center border border-zinc-700 px-8 py-4 font-mono text-sm uppercase tracking-widest text-zinc-300 transition-all hover:border-zinc-500 hover:text-white"
					>
						See Results
					</a>
				</div>

				<div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4 border-t border-zinc-800 pt-8">
					<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">Proven in</p>
					{
						proof.map((item) => (
							<span class="font-mono text-xs text-zinc-400">{item}</span>
						))
					}
				</div>
			</div>

			<div class="md:col-span-4">
				<HeroScene />
			</div>
		</div>
	</div>
</section>

<style>
	.hero-headline {
		transition:
			opacity 380ms ease,
			transform 380ms ease;
	}

	.hero-headline.is-fading {
		opacity: 0;
		transform: translateY(0.35rem);
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-headline,
		.hero-headline.is-fading {
			transition: none;
			transform: none;
			opacity: 1;
		}
	}
</style>

<script>
	import { initHeroHeadlines } from '../scripts/hero-headlines';

	const root = document.querySelector('[data-hero-headline]');
	if (root instanceof HTMLElement) {
		initHeroHeadlines(root);
	}
</script>
