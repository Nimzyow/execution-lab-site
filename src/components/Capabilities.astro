---
const capabilities = [
	{
		index: '01',
		title: 'Product Software That Ships',
		description:
			'Build and modernize full-stack apps—Next.js, TypeScript, React Native—so you get a working product, not a prototype.',
		benefit: 'Faster time to market · Real users',
	},
	{
		index: '02',
		title: 'Custom Tooling & Automation ROI',
		description:
			'Cut 700-hour legacy workflows to 1-hour runs with purpose-built tools—same output, fraction of labour cost.',
		benefit: 'Faster delivery · Lower OpEx',
	},
	{
		index: '03',
		title: 'Platform Reliability & Cost Recovery',
		description:
			'Harden AWS, automate deploys, shut idle spend—without risking data integrity or release cadence.',
		benefit: 'Lower cloud bill · Lower outage risk',
	},
];
---

<section id="capabilities" class="border-b border-zinc-800 py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="mb-16 grid grid-cols-1 gap-6 md:grid-cols-12">
			<div class="md:col-span-5">
				<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">
					Proven Capabilities
				</p>
				<h2 class="mt-4 text-3xl font-light tracking-tight text-white md:text-4xl">
					Execution, not slide decks.
				</h2>
			</div>
			<div class="flex items-end md:col-span-7">
				<p class="max-w-lg text-zinc-500">
					We don't write pitch decks. We write software—apps, tooling, and the platforms that run
					them in production.
				</p>
			</div>
		</div>

		<div class="grid grid-cols-1 gap-4 md:grid-cols-3">
			{
				capabilities.map((cap) => (
					<article class="group border border-zinc-800 p-8 transition-all hover:border-zinc-600 hover:bg-ink-elevated">
						<div class="flex items-center justify-between">
							<span class="font-mono text-sm text-accent">{cap.index}</span>
							<span
								class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-700 transition-colors group-hover:text-zinc-500"
							>
								Pillar
							</span>
						</div>
						<h3 class="mt-8 text-lg font-medium tracking-tight text-white">{cap.title}</h3>
						<p class="mt-4 text-sm leading-relaxed text-zinc-500">{cap.description}</p>
						<p class="mt-6 font-mono text-[10px] uppercase tracking-[0.2em] text-accent">
							{cap.benefit}
						</p>
					</article>
				))
			}
		</div>
	</div>
</section>
