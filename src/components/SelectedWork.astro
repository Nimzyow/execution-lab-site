---
const caseStudies = [
	{
		id: 'recommends',
		badge: 'Live on App Store',
		title: 'Recommends',
		subtitle: 'recommends.app',
		url: 'https://apps.apple.com/gb/app/recommends/id6740585961',
		cta: 'View on App Store',
		challenge:
			'Manual dish cataloguing and ad-hoc releases blocked launch velocity and made every update a production risk.',
		solutions: [
			'Built and shipped a full-stack React Native consumer app to the App Store',
			'Integrated photo → dish recognition to cut manual cataloguing and speed content capture',
			'Built supporting tooling and automated infra so releases stopped depending on heroics',
		],
		results: [
			{ metric: 'App Store', label: 'live consumer product' },
			{ metric: 'Photo → dish', label: 'AI capture in one step' },
			{ metric: 'Automated', label: 'release path to production' },
		],
		visual: {
			type: 'phone' as const,
			src: '/images/recommends-screenshot.png',
			alt: 'Recommends iOS app — Discover feed showing a dish recommendation',
			width: 456,
			height: 900,
		},
	},
	{
		id: 'olympo',
		badge: 'Board governance platform',
		title: 'OLYMPO Board Intelligence',
		subtitle: 'olympo.lu',
		url: 'https://olympo.lu',
		cta: 'Visit OLYMPO',
		challenge:
			'Board appointments are high-trust and compliance-heavy. Generic job boards cannot verify credentials, protect sensitive documents, or support Luxembourg/EU governance workflows.',
		solutions: [
			'Built an end-to-end board recruitment journey—profiles, scored matching, applications, and messaging—so companies and directors meet on fit, not noise',
			'Made credentials and hiring audit-friendly with private-by-default document handling, admin verification, and structured application status',
			'Extended beyond jobs into sitting-director ops: CSSF-oriented KYC/mandates, governance calendar, and AI meeting minutes from recordings',
		],
		results: [
			{ metric: 'Private-by-default', label: 'document vault' },
			{ metric: 'CSSF-oriented', label: 'KYC & mandate workflows' },
			{ metric: 'Full journey', label: 'match → apply → verify' },
		],
		visual: {
			type: 'brand' as const,
			icon: '/images/olympo-icon.svg',
			label: 'OLYMPO',
			tagline: 'Connect the right people to the right boards',
			chips: ['Matching', 'Verification', 'KYC', 'Private docs', 'AI minutes'],
		},
	},
];
---

<section id="work" class="border-b border-zinc-800 py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="mb-16 grid grid-cols-1 gap-6 md:grid-cols-12">
			<div class="md:col-span-5">
				<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">Selected Work</p>
				<h2 class="mt-4 text-3xl font-light tracking-tight text-white md:text-4xl">
					Shipped to production.
				</h2>
			</div>
			<div class="flex items-end md:col-span-7">
				<p class="max-w-lg text-zinc-500">
					Consumer products and trust-critical platforms—full-stack software, AI features, and the
					infra to run them.
				</p>
			</div>
		</div>

		<div class="space-y-8">
			{
				caseStudies.map((study) => (
					<article class="border border-zinc-800 bg-ink-elevated">
						<div class="grid grid-cols-1 md:grid-cols-12">
							<div class="border-b border-zinc-800 p-8 md:col-span-7 md:border-r md:border-b-0 md:p-10">
								<div class="flex flex-wrap items-center gap-3">
									<span class="font-mono text-xs text-accent">Case Study</span>
									<span class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">
										{study.badge}
									</span>
								</div>

								<h3 class="mt-6 text-2xl font-medium tracking-tight text-white md:text-3xl">
									<a
										href={study.url}
										target="_blank"
										rel="noopener noreferrer"
										class="transition-colors hover:text-accent"
									>
										{study.title}
									</a>
								</h3>
								<p class="mt-1 font-mono text-sm text-zinc-500">{study.subtitle}</p>

								<div class="mt-8 space-y-8">
									<div>
										<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">
											Challenge
										</p>
										<p class="mt-3 text-sm leading-relaxed text-zinc-400">{study.challenge}</p>
									</div>

									<div>
										<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">
											Solution
										</p>
										<ul class="mt-3 space-y-3">
											{study.solutions.map((item) => (
												<li class="flex gap-3 text-sm text-zinc-400">
													<span class="mt-1.5 h-px w-3 shrink-0 bg-accent" aria-hidden="true" />
													{item}
												</li>
											))}
										</ul>
									</div>

									<div>
										<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">
											Impact
										</p>
										<ul class="mt-3 flex flex-wrap gap-2">
											{study.results.map((result) => (
												<li class="border border-zinc-800 px-3 py-1 font-mono text-xs text-zinc-400">
													<span class="text-white">{result.metric}</span> {result.label}
												</li>
											))}
										</ul>
									</div>
								</div>

								<a
									href={study.url}
									target="_blank"
									rel="noopener noreferrer"
									class="mt-10 inline-flex items-center gap-3 border border-zinc-700 px-6 py-3 font-mono text-xs uppercase tracking-widest text-zinc-300 transition-all hover:border-accent hover:text-white"
								>
									{study.cta}
									<span aria-hidden="true">↗</span>
								</a>
							</div>

							<div class="flex items-center justify-center bg-ink p-8 md:col-span-5 md:p-10">
								{study.visual.type === 'phone' ? (
									<a
										href={study.url}
										target="_blank"
										rel="noopener noreferrer"
										class="group block w-full max-w-[240px]"
										aria-label={`${study.title} — ${study.cta}`}
									>
										<div class="overflow-hidden rounded-[2rem] border border-zinc-700 bg-zinc-900 shadow-[0_0_0_1px_rgba(255,255,255,0.04)] transition-transform duration-300 group-hover:scale-[1.02]">
											<img
												src={study.visual.src}
												alt={study.visual.alt}
												width={study.visual.width}
												height={study.visual.height}
												loading="lazy"
												decoding="async"
												class="h-auto w-full"
											/>
										</div>
									</a>
								) : (
									<a
										href={study.url}
										target="_blank"
										rel="noopener noreferrer"
										class="group block w-full max-w-sm"
										aria-label={`${study.title} — ${study.cta}`}
									>
										<div class="border border-zinc-700 bg-[#2d2d2d] p-8 transition-transform duration-300 group-hover:scale-[1.02]">
											<div class="flex items-center gap-4">
												<img
													src={study.visual.icon}
													alt=""
													width="48"
													height="48"
													class="h-12 w-12 rounded-xl"
												/>
												<div>
													<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#ffb22c]">
														Platform
													</p>
													<p class="mt-1 text-lg font-medium text-white">{study.visual.label}</p>
												</div>
											</div>
											<p class="mt-6 text-sm leading-relaxed text-zinc-400">
												{study.visual.tagline}
											</p>
											<ul class="mt-8 flex flex-wrap gap-2">
												{study.visual.chips.map((chip) => (
													<li class="border border-zinc-600 px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-zinc-300">
														{chip}
													</li>
												))}
											</ul>
											<div class="mt-8 border-t border-zinc-600 pt-6">
												<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-500">
													Luxembourg · EU governance
												</p>
											</div>
										</div>
									</a>
								)}
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
