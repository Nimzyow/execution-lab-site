<div
	class="hero-scene relative h-[280px] w-full overflow-hidden border border-zinc-800 bg-ink-elevated sm:h-[340px] md:h-full md:min-h-[420px]"
	data-hero-scene
>
	<canvas class="absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

	<div
		class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_35%,#111113_78%)]"
		aria-hidden="true"
	>
	</div>
</div>

<script>
	import { initHeroScene } from '../scripts/hero-scene';

	document.querySelectorAll('[data-hero-scene]').forEach((container) => {
		const canvas = container.querySelector('canvas');
		if (canvas instanceof HTMLCanvasElement && container instanceof HTMLElement) {
			initHeroScene(canvas, container);
		}
	});
</script>
