---
const steps = [
	{
		step: '01',
		title: 'Discovery',
		body: 'Map the bottleneck, risk, and cost of inaction in 1–2 sessions.',
	},
	{
		step: '02',
		title: 'Roadmap',
		body: 'Fixed scope, milestones, and success metrics before any build starts.',
	},
	{
		step: '03',
		title: 'Execution',
		body: 'Ship in production increments. Weekly demos. No black-box sprints.',
	},
	{
		step: '04',
		title: 'Hand-off',
		body: 'Docs, runbooks, and knowledge transfer so your team owns the outcome.',
	},
];
---

<section id="process" class="border-b border-zinc-800 py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="mb-16 grid grid-cols-1 gap-6 md:grid-cols-12">
			<div class="md:col-span-5">
				<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">How We Work</p>
				<h2 class="mt-4 text-3xl font-light tracking-tight text-white md:text-4xl">
					Clear process. No surprises.
				</h2>
			</div>
			<div class="flex items-end md:col-span-7">
				<p class="max-w-lg text-zinc-500">
					From first call to hand-off—scoped, demoed weekly, and built for your team to own.
				</p>
			</div>
		</div>

		<div class="grid grid-cols-1 gap-4 md:grid-cols-4">
			{
				steps.map((item, i) => (
					<article class="relative border border-zinc-800 p-8 transition-colors hover:border-zinc-600 hover:bg-ink-elevated">
						<span class="font-mono text-sm text-accent">{item.step}</span>
						{i < steps.length - 1 && (
							<span
								class="pointer-events-none absolute top-10 right-0 hidden h-px w-4 translate-x-full bg-zinc-800 md:block"
								aria-hidden="true"
							/>
						)}
						<h3 class="mt-6 text-lg font-medium tracking-tight text-white">{item.title}</h3>
						<p class="mt-4 text-sm leading-relaxed text-zinc-500">{item.body}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
