---
const profiles = [
	{
		id: 'A',
		role: 'The Cloud & Infrastructure Bedrock',
		focus: [
			'Enterprise AWS Architecture',
			'Linux Systems',
			'High-Availability Microservices',
			'CI/CD Engine',
		],
		track:
			'Lead Software Development Engineer at Mastercard, 8+ years at Rackspace moving through the ranks from Support to Senior Linux Operations Engineer. Expert in hard-nosed virtualization, Jenkins automation, and bulletproof infrastructure.',
		span: 'md:col-span-7',
		offset: '',
	},
	{
		id: 'B',
		role: 'The Full-Stack & Automation Accelerator',
		focus: [
			'React/TypeScript Architecture',
			'Advanced Python/Django',
			'MLOps',
			'Custom Automation Tools',
		],
		track:
			'Senior Software Engineer at Vocalink (a Mastercard company), ex-Ripple Energy. Known for architecting custom internal automation tools that cut project migration times from 700 hours to a single hour, overhauling legacy Java stacks into modern React/TS ecosystems using Agentic AI, and driving aggressive AWS cost reductions.',
		span: 'md:col-span-5',
		offset: 'md:mt-16',
	},
];
---

<section id="pedigree" class="border-b border-zinc-800 py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="mb-16 grid grid-cols-1 gap-6 md:grid-cols-12">
			<div class="md:col-span-6">
				<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">The Pedigree</p>
				<h2 class="mt-4 text-3xl font-light tracking-tight text-white md:text-4xl">
					A unified powerhouse team.
				</h2>
			</div>
			<div class="flex items-end md:col-span-6">
				<p class="max-w-md text-zinc-500">
					Twelve years of hardcore cloud infrastructure and Linux operations, merged with elite
					full-stack product engineering and AI-driven automation.
				</p>
			</div>
		</div>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-12">
			{
				profiles.map((profile) => (
					<article
						class={`border border-zinc-800 bg-ink-elevated p-8 transition-colors hover:border-zinc-700 md:p-10 ${profile.span} ${profile.offset}`}
					>
						<div class="flex items-start justify-between">
							<span class="font-mono text-xs text-zinc-600">Profile {profile.id}</span>
							<span
								class="h-px w-12 bg-accent"
								aria-hidden="true"
							/>
						</div>

						<h3 class="mt-6 text-xl font-medium tracking-tight text-white md:text-2xl">
							{profile.role}
						</h3>

						<div class="mt-8">
							<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">Focus</p>
							<ul class="mt-3 flex flex-wrap gap-2">
								{profile.focus.map((item) => (
									<li class="border border-zinc-800 px-3 py-1 font-mono text-xs text-zinc-400">
										{item}
									</li>
								))}
							</ul>
						</div>

						<div class="mt-8 border-t border-zinc-800 pt-8">
							<p class="font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">
								Track Record
							</p>
							<p class="mt-3 text-sm leading-relaxed text-zinc-400">{profile.track}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
