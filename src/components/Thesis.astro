---
const pillars = [
	{
		index: '01',
		title: 'Software Craft, End to End',
		body: 'We build the product—web, mobile, APIs, and internal tools—not just the plumbing under it. Clean TypeScript codebases, modern frameworks, and features that users actually touch.',
	},
	{
		index: '02',
		title: 'Tooling That Pays for Itself',
		body: 'Custom automation and developer tooling that collapses months of manual work into hours. No generic templates—purpose-built systems for your bottleneck.',
	},
	{
		index: '03',
		title: 'Platform Discipline',
		body: 'Rooted in zero-downtime Linux ops and enterprise payment pipelines. Every release path is resilient, tested, and built for high-stakes environments.',
	},
];
---

<section id="thesis" class="border-b border-zinc-800 py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="grid grid-cols-1 gap-12 md:grid-cols-12">
			<div class="md:col-span-4">
				<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">The Core Thesis</p>
				<h2 class="mt-4 text-3xl font-light tracking-tight text-white md:text-4xl">
					Builders first. Platform when it matters.
				</h2>
				<p class="mt-4 max-w-sm text-zinc-500">
					Product software and production infrastructure—same bar for both.
				</p>
			</div>

			<div class="grid grid-cols-1 gap-px bg-zinc-800 md:col-span-8 md:grid-cols-3">
				{
					pillars.map((pillar) => (
						<article class="group bg-ink p-8 transition-colors hover:bg-ink-elevated">
							<span class="font-mono text-xs text-zinc-600 transition-colors group-hover:text-accent">
								{pillar.index}
							</span>
							<h3 class="mt-6 text-lg font-medium tracking-tight text-white">{pillar.title}</h3>
							<p class="mt-4 text-sm leading-relaxed text-zinc-500">{pillar.body}</p>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>
