---
const models = [
	{ name: 'Fixed-Scope', detail: 'Defined outcome, fixed fee' },
	{ name: 'Retainer', detail: 'Ongoing capacity for critical systems' },
	{ name: 'Fractional Lead', detail: 'Product architecture + delivery oversight' },
];

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
---

<section id="contact" class="py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="grid grid-cols-1 gap-16 md:grid-cols-12">
			<div class="md:col-span-5">
				<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">Engagement</p>
				<h2 class="mt-4 text-3xl font-light tracking-tight text-white md:text-4xl">
					The handshake.
				</h2>
				<p class="mt-6 max-w-sm leading-relaxed text-zinc-400">
					Three ways to engage. Day rates from £800. We start with a paid discovery call.
				</p>

				<ul class="mt-6 space-y-3">
					{
						models.map((model) => (
							<li class="border-l border-accent pl-4">
								<p class="font-mono text-xs text-white">{model.name}</p>
								<p class="mt-1 text-sm text-zinc-500">{model.detail}</p>
							</li>
						))
					}
				</ul>
			</div>

			<div class="md:col-span-7">
				<form
					id="contact-form"
					class="border border-zinc-800 bg-ink-elevated p-8 md:p-10"
					method="POST"
					novalidate
					data-access-key={accessKey}
				>
					<input type="hidden" name="subject" value="Discovery call request — S/NERGY LABS" />
					<input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

					<p class="mb-8 font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-600">
						// contact.init()
					</p>

					<div data-form-fields class="space-y-6">
						<div>
							<label for="name" class="mb-2 block font-mono text-xs text-zinc-500">
								name: string
							</label>
							<input
								type="text"
								id="name"
								name="name"
								required
								autocomplete="name"
								class="w-full border border-zinc-800 bg-ink px-4 py-3 font-mono text-sm text-white placeholder:text-zinc-700 transition-colors focus:border-accent focus:outline-none"
								placeholder='"Your name"'
							/>
						</div>

						<div>
							<label for="email-input" class="mb-2 block font-mono text-xs text-zinc-500">
								email: string
							</label>
							<input
								type="email"
								id="email-input"
								name="email"
								required
								autocomplete="email"
								class="w-full border border-zinc-800 bg-ink px-4 py-3 font-mono text-sm text-white placeholder:text-zinc-700 transition-colors focus:border-accent focus:outline-none"
								placeholder='"you@company.com"'
							/>
						</div>

						<div>
							<label for="phone" class="mb-2 block font-mono text-xs text-zinc-500">
								phone?: string
								<span class="ml-2 text-zinc-700">optional</span>
							</label>
							<input
								type="tel"
								id="phone"
								name="phone"
								autocomplete="tel"
								class="w-full border border-zinc-800 bg-ink px-4 py-3 font-mono text-sm text-white placeholder:text-zinc-700 transition-colors focus:border-accent focus:outline-none"
								placeholder='"+44 7700 900000"'
							/>
						</div>

						<div>
							<label for="message" class="mb-2 block font-mono text-xs text-zinc-500">
								bottleneck: string
							</label>
							<textarea
								id="message"
								name="message"
								rows="5"
								required
								class="w-full resize-none border border-zinc-800 bg-ink px-4 py-3 font-mono text-sm text-white placeholder:text-zinc-700 transition-colors focus:border-accent focus:outline-none"
								placeholder='"Describe the challenge..."'
							></textarea>
						</div>
					</div>

					<p
						data-form-status
						class="mt-6 hidden font-mono text-xs"
						role="status"
						aria-live="polite"
					>
					</p>

					<div
						data-form-success
						class="hidden border border-emerald-500/40 bg-emerald-500/10 p-6"
						role="status"
						aria-live="polite"
					>
						<p class="font-mono text-xs uppercase tracking-widest text-emerald-400">Request received</p>
						<p class="mt-3 text-sm leading-relaxed text-zinc-300">
							Thanks — we'll review your note and follow up shortly to schedule a discovery call.
						</p>
					</div>

					<button
						type="submit"
						data-form-submit
						class="mt-8 w-full bg-accent py-4 font-mono text-sm uppercase tracking-widest text-white transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto sm:px-12"
					>
						Request a Discovery Call
					</button>
				</form>
			</div>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById('contact-form');
	if (form instanceof HTMLFormElement) {
		const status = form.querySelector('[data-form-status]');
		const success = form.querySelector('[data-form-success]');
		const fields = form.querySelector('[data-form-fields]');
		const submit = form.querySelector('[data-form-submit]');
		const accessKey = form.dataset.accessKey?.trim() ?? '';

		const setStatus = (message: string, kind: 'error' | 'info') => {
			if (!(status instanceof HTMLElement)) return;
			status.textContent = message;
			status.classList.remove('hidden', 'text-zinc-500', 'text-accent', 'text-red-400');
			status.classList.add(kind === 'error' ? 'text-red-400' : 'text-zinc-500');
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();

			if (!accessKey) {
				setStatus(
					'Form is not configured yet. Add PUBLIC_WEB3FORMS_ACCESS_KEY to enable submissions.',
					'error',
				);
				return;
			}

			if (!(submit instanceof HTMLButtonElement)) return;

			submit.disabled = true;
			submit.textContent = 'Sending…';
			setStatus('Submitting securely…', 'info');

			const phone = (form.elements.namedItem('phone') as HTMLInputElement).value.trim();
			const payload: Record<string, string | boolean> = {
				access_key: accessKey,
				subject: 'Discovery call request — S/NERGY LABS',
				from_name: 'S/NERGY LABS site',
				name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
				email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
				message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
				botcheck: false,
			};
			if (phone) payload.phone = phone;

			try {
				const response = await fetch('https://api.web3forms.com/submit', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify(payload),
				});
				const result = (await response.json()) as { message?: string; success?: boolean };

				if (!response.ok || result.success === false) {
					throw new Error(result.message || 'Submission failed');
				}

				form.reset();
				if (status instanceof HTMLElement) status.classList.add('hidden');
				if (fields instanceof HTMLElement) fields.classList.add('hidden');
				submit.classList.add('hidden');
				if (success instanceof HTMLElement) success.classList.remove('hidden');
			} catch {
				setStatus('Something went wrong. Please try again in a moment.', 'error');
				submit.disabled = false;
				submit.textContent = 'Request a Discovery Call';
			}
		});
	}
</script>
